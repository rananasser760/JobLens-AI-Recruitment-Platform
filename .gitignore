# ---------------------------------------------------
# JobLens AI .gitignore
# ---------------------------------------------------

# 1. Output Reports & Alert Frames
outputs/

# 2. Python Cache Files
__pycache__/
*.py[cod]
*$py.class

# 3. Database (Don't commit real candidate data!)
joblens.db

# 4. Temporary Audio Files (From STT/TTS engine)
temp_raw_*.webm
temp_clean_*.wav
*.mp3
temp_audio/

# 5. Vector DB and model caches
joblens_db/
.cache/

# 5b. ML model artifacts
*.pt
*.pth

# 6. Environment secrets
.env
.env.local

# 7. Frontend build artifacts (future integration)
dist/
build/
