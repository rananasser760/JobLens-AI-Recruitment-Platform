# ---------------------------------------------------
# JobLens AI - Root gitignore
# ---------------------------------------------------

# 1. Project Output Reports & Alert Frames
outputs/

# 2. Python Cache Files & Virtual Envs
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
.venv*/
ENV/
env/
.pytest_cache/
.tox/
.coverage
htmlcov/
pip-log.txt
pip-delete-this-directory.txt

# 3. Database (Don't commit real database or candidate data)
joblens.db
joblens_db/
*.db
*.sqlite

# 4. Temporary Audio & Media Files (From STT/TTS engine)
temp_raw_*.webm
temp_clean_*.wav
*.mp3
temp_audio/

# 5. ML model artifacts and caches
.cache/
*.pt
*.pth

# 6. Environment secrets
.env
.env.*
!.env.example

# 7. Node / Angular dependencies and build outputs
node_modules/
.angular/
dist/
tmp/
out-tsc/
bazel-out/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.sass-cache/

# 8. Local IDE, editors, and tooling state
.vs/
.vscode/
.idea/
.cursor/
.history/
*.suo
*.user
*.userosscache
*.sln.docstates
*.launch
.settings/
*.sublime-workspace

# 9. Local build/artifact output
.artifacts/
**/[Aa]rtifacts/

# 10. Local .NET build output
[Bb]in/
[Oo]bj/
**/[Bb]in/
**/[Oo]bj/

# 11. Operating System files
.DS_Store
Thumbs.db
desktop.ini
