# ---------------------------------------------------
# GP_MAIN monorepo .gitignore
# Covers:
# - GP_AI (Python)
# - GP_Backend (.NET)
# - GP_Front (Angular/Node)
# ---------------------------------------------------

# OS and editor noise
.DS_Store
Thumbs.db
Desktop.ini

.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# Environment and secrets
.env
.env.*
!.env.example
*.secret

# Logs and runtime files
*.log
*.pid
npm-debug.log*
yarn-error.log*

# ---------------------------------------------------
# Python (GP_AI)
# ---------------------------------------------------
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Python virtual environments
.venv/
venv/
env/
ENV/
**/.venv/
**/venv/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.ipynb_checkpoints/

# Local databases and temp artifacts
*.db
*.sqlite
*.sqlite3
joblens.db

# GP_AI runtime output and temp audio
GP_AI/outputs/
GP_AI/temp_raw_*.webm
GP_AI/temp_clean_*.wav
GP_AI/*.mp3

# ---------------------------------------------------
# .NET / Visual Studio (GP_Backend)
# ---------------------------------------------------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Ll]og/
[Ll]ogs/

.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

TestResult*/
*.trx
*.coverage
*.coveragexml

# NuGet and generated artifacts
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
artifacts/

# ---------------------------------------------------
# Node / Angular (GP_Front)
# ---------------------------------------------------
node_modules/
dist/
tmp/
out-tsc/
bazel-out/
.angular/cache/
coverage/
.sass-cache/

# Optional local screenshots/output
__screenshots__/
