# JobLens Configuration File
# Copy this to .env and customize as needed

# ==================== DATABASE CONFIGURATION ====================
CHROMA_DB_PATH=./joblens_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==================== API CONFIGURATION ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ==================== SCRAPING CONFIGURATION ====================

# Maximum concurrent scraping tasks
MAX_CONCURRENT_SCRAPES=3

# Rate limiting (requests per minute per source)
WUZZUF_RATE_LIMIT=30
LINKEDIN_RATE_LIMIT=20
FORASNA_RATE_LIMIT=30

# Default scraping delays (seconds)
MIN_DELAY=2.0
MAX_DELAY=5.0

# Default max pages per category
DEFAULT_MAX_PAGES=3

# Enable/disable sources
WUZZUF_ENABLED=true
LINKEDIN_ENABLED=true
FORASNA_ENABLED=true
INDEED_ENABLED=false
GLASSDOOR_ENABLED=false

# ==================== PLAYWRIGHT CONFIGURATION ====================
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
BROWSER_WIDTH=1920
BROWSER_HEIGHT=1080

# ==================== EGYPT MARKET CONFIGURATION ====================

# Primary location
DEFAULT_LOCATION=Egypt

# Supported cities
SUPPORTED_CITIES=Cairo,Giza,Alexandria,Mansoura,Tanta,Asyut,Ismailia,Aswan,Luxor

# Enable Arabic keywords
ENABLE_ARABIC_KEYWORDS=true

# ==================== CATEGORY PRIORITIES ====================

# High-demand categories (scraped first)
HIGH_DEMAND_CATEGORIES=Data & AI,IT & Software Development,Cybersecurity,Renewable Energy,Engineering - Mech/Elec

# ==================== DATA RETENTION ====================

# Maximum age of jobs in database (days)
# Jobs older than this will be marked as expired
MAX_JOB_AGE_DAYS=30

# Auto-cleanup interval (hours)
CLEANUP_INTERVAL_HOURS=24

# ==================== OPTIONAL: REDIS CONFIGURATION ====================
# Uncomment and configure if using Redis for caching

# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=
# CACHE_TTL_SECONDS=3600

# ==================== OPTIONAL: POSTGRESQL CONFIGURATION ====================
# Uncomment and configure if using PostgreSQL for persistent storage

# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=joblens
# DB_USER=joblens_user
# DB_PASSWORD=your_secure_password

# ==================== LOGGING CONFIGURATION ====================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/joblens.log

# Enable detailed scraping logs
DETAILED_LOGS=false

# ==================== ADVANCED CONFIGURATION ====================

# Number of retries for failed requests
MAX_RETRIES=3

# Duplicate detection sensitivity (0.0 - 1.0)
# Higher = stricter duplicate detection
DUPLICATE_THRESHOLD=0.95

# Enable stealth mode (anti-detection)
ENABLE_STEALTH=true

# User agent rotation
ROTATE_USER_AGENTS=true

# ==================== FEATURE FLAGS ====================

# Enable semantic search
ENABLE_SEMANTIC_SEARCH=true

# Enable skill extraction
ENABLE_SKILL_EXTRACTION=true

# Enable salary parsing
ENABLE_SALARY_PARSING=true

# Enable job categorization
ENABLE_AUTO_CATEGORIZATION=true

# ==================== MONITORING ====================

# Enable performance metrics
ENABLE_METRICS=false

# Metrics endpoint port
METRICS_PORT=9090

# Enable health checks
ENABLE_HEALTH_CHECKS=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60
