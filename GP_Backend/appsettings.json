{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=GPDB;Integrated Security=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "JobLensAPI",
    "Audience": "JobLensClient",
    "ExpirationInHours": 1
  },
  "AIBackend": {
    "BaseUrl": "http://localhost:8000",
    "Timeout": 300,
    "ApiKey": "change_me_internal_api_key"
  },
  "Email": {
    "FromAddress": "noreply@joblens.com",
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": ""
  },
  "FileStorage": {
    "BasePath": "uploads"
  },
  "FrontendUrl": "http://localhost:4200",
  "AllowedHosts": "*"
}
