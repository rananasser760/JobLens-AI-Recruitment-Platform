# LLM provider selection: openrouter or groq
JOBLENS_LLM_PROVIDER=openrouter

# Set the key matching the selected provider
OPENROUTER_API_KEY="your_openrouter_api_key_here"
GROQ_API_KEY="your_groq_api_key_here"
JOBLENS_INTERVIEW_MODEL=mistralai/mistral-small-3.2-24b-instruct

# Optional model overrides
JOBLENS_PARSING_MODEL=meta-llama/llama-3.3-70b-instruct
JOBLENS_PARSING_FALLBACK_MODEL=meta-llama/llama-3.1-70b-instruct
JOBLENS_ATS_MODEL=meta-llama/llama-3.3-70b-instruct
JOBLENS_SCORING_MODEL=meta-llama/llama-3.3-70b-instruct
JOBLENS_OCR_MODEL=meta-llama/llama-3.2-90b-vision-preview

# ChromaDB and scheduler settings
JOBLENS_CHROMA_PATH=./joblens_db
JOBLENS_SCRAPER_INTERVAL_HOURS=6
JOBLENS_SCRAPER_SCHEDULED=false
JOBLENS_SCRAPER_CONCURRENCY=5
JOBLENS_CORS_ORIGINS=*

# Optional embedding model overrides
JOBLENS_SCRAPER_EMBEDDING_MODEL=all-MiniLM-L6-v2
JOBLENS_CV_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
